<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0"
         metadata-complete="true">
 
    <!-- metadata-complete="true" le dice a Tomcat que IGNORE
    las anotaciones @WebServlet en las clases Java.
    Todo el mapeo se hace AQUÍ únicamente. -->
 
    <display-name>SEAEA</display-name>
 
    <!-- ══════════════════════════════════════════════════════
    PÁGINA DE BIENVENIDA
    ══════════════════════════════════════════════════════ -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>
 
    <!-- ══════════════════════════════════════════════════════
    SERVLET: Login
    ══════════════════════════════════════════════════════ -->
    <servlet>
        <servlet-name>LoginControlador</servlet-name>
        <servlet-class>controlador.LoginControlador</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginControlador</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
 
    <!-- ══════════════════════════════════════════════════════
    SERVLET: Menu
    ══════════════════════════════════════════════════════ -->
    <servlet>
        <servlet-name>MenuControlador</servlet-name>
        <servlet-class>controlador.MenuControlador</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MenuControlador</servlet-name>
        <url-pattern>/menu</url-pattern>
    </servlet-mapping>
 
    <!-- ══════════════════════════════════════════════════════
    SERVLETS: Escenarios
    ══════════════════════════════════════════════════════ -->
    <servlet>
        <servlet-name>EscenarioUnoControlador</servlet-name>
        <servlet-class>controlador.EscenarioUnoControlador</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EscenarioUnoControlador</servlet-name>
        <url-pattern>/escenario1</url-pattern>
    </servlet-mapping>
 
    <servlet>
        <servlet-name>EscenarioDosControlador</servlet-name>
        <servlet-class>controlador.EscenarioDosControlador</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EscenarioDosControlador</servlet-name>
        <url-pattern>/escenario2</url-pattern>
    </servlet-mapping>
 
    <servlet>
        <servlet-name>EscenarioTresControlador</servlet-name>
        <servlet-class>controlador.EscenarioTresControlador</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EscenarioTresControlador</servlet-name>
        <url-pattern>/escenario3</url-pattern>
    </servlet-mapping>
 
    <servlet>
        <servlet-name>EscenarioCuatroControlador</servlet-name>
        <servlet-class>controlador.EscenarioCuatroControlador</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EscenarioCuatroControlador</servlet-name>
        <url-pattern>/escenario4</url-pattern>
    </servlet-mapping>
 
    <servlet>
        <servlet-name>EscenarioCincoControlador</servlet-name>
        <servlet-class>controlador.EscenarioCincoControlador</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EscenarioCincoControlador</servlet-name>
        <url-pattern>/escenario5</url-pattern>
    </servlet-mapping>
 
    <servlet>
        <servlet-name>EscenarioSeisControlador</servlet-name>
        <servlet-class>controlador.EscenarioSeisControlador</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EscenarioSeisControlador</servlet-name>
        <url-pattern>/escenario6</url-pattern>
    </servlet-mapping>
 
    <!-- ══════════════════════════════════════════════════════
    SERVLET: Test de conexión
    ══════════════════════════════════════════════════════ -->
    <servlet>
        <servlet-name>TestConexionServlet</servlet-name>
        <servlet-class>controlador.TestConexionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TestConexionServlet</servlet-name>
        <url-pattern>/testConexion</url-pattern>
    </servlet-mapping>
 
    <!-- ══════════════════════════════════════════════════════
    SESIÓN
    ══════════════════════════════════════════════════════ -->
    <session-config>
        <session-timeout>60</session-timeout>
    </session-config>
 
    <!-- ══════════════════════════════════════════════════════
    PÁGINAS DE ERROR
    ══════════════════════════════════════════════════════ -->
    <error-page>
        <error-code>404</error-code>
        <location>/login</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/login</location>
    </error-page>
 
</web-app>
 